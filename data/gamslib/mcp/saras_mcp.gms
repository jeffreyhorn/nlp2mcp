    EGMR /0/
    ECGMR /0/
    ELGMR /0/
    ECNMR /0/
    ELNMR /0/
    GM /0/
    AvedeRY /0/
    tAvedeRY /0/
    CovGMR /0/
    VarGMR /0/
    TVarGMR /0/
    StDGMR /0/
    tstdgmr /0/
    ECRGMR /0/
    ELRGMR /0/
    preFECY /0/
    preFEMY /0/
    preFELY /0/
    EFMR /0/
    EFCY /0/
    EFLY /0/
    idlecost /0/
    c_ss /0/

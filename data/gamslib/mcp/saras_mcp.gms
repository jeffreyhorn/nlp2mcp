    elas(r,f,p) /FState.f1.Wmaize 0.074, FState.f1.YMaize 0.123, FState.f1.Wheat 0.101, FState.f1.Soya 0.112, FState.f1.Sorghum 0.17, FState.f1.sunflower 0.276, FState.f2.Wmaize 0.037, FState.f2.YMaize 0.062, FState.f2.Wheat 0.051, FState.f2.Soya 0.056, FState.f2.Sorghum 0.085, FState.f2.sunflower 0.138/
;

Scalars
    CDAVC /0/
    RCDAVC /0/
    RRCDAVC /0/
    LDAVC /0/
    RLDAVC /0/
    RRLDAVC /0/
    p_int_paid /0/
    CY /0/
    AY /0/
    sumt /0/
    sumtsq /0/
    meant /0/
    pRY /0/
    AMYrisk /0/
    pMY /0/
    pRPrice /0/
    lpreRGM /0/
    risk /0/
    sumrisk /0/
    prgm /0/
    dergm /0/
    ECY /0/
    ECY1 /0/
    ELY /0/
    EY /0/
    EMY /0/

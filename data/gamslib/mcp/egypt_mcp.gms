to.'w-onion'.'e-delta' 0, potato.'w-onion'.'m-delta' 0, potato.'w-onion'.'w-delta' 0, potato.'w-tomato'.'u-egypt' 0, potato.'w-tomato'.'m-egypt' 0, potato.'w-tomato'.'e-delta' 0, potato.'w-tomato'.'m-delta' 0, potato.'w-tomato'.'w-delta' 0, potato.'w-veget'.'u-egypt' 0, potato.'w-veget'.'m-egypt' 0, potato.'w-veget'.'e-delta' 0, potato.'w-veget'.'m-delta' 0, potato.'w-veget'.'w-delta' 0, potato.cotton.'u-egypt' 0, potato.cotton.'m-egypt' 0, potato.cotton.'e-delta' 0, potato.cotton.'m-delta' 0, potato.cotton.'w-delta' 0, potato.rice.'u-egypt' 0, potato.rice.'m-egypt' 0, potato.rice.'e-delta' 0, potato.rice.'m-delta' 0, potato.rice.'w-delta' 0, potato.'s-maize'.'u-egypt' 0, potato.'s-maize'.'m-egypt' 0, potato.'s-maize'.'e-delta' 0, potato.'s-maize'.'m-delta' 0, potato.'s-maize'.'w-delta' 0, potato.sorghum.'u-egypt' 0, potato.sorghum.'m-egypt' 0, potato.sorghum.'e-delta' 0, potato.sorghum.'m-delta' 0, potato.sorghum.'w-delta' 0, potato.soyabeans.'u-egypt' 0, potato.soyabeans.'m-egypt' 0, potato.soyabeans.'e-delta' 0, potato.soyabeans.'m-delta' 0, potato.soyabeans.'w-delta' 0, potato.groundnut.'u-egypt' 0, potato.groundnut.'m-egypt' 0, potato.groundnut.'e-delta' 0, potato.groundnut.'m-delta' 0, potato.groundnut.'w-delta' 0, potato.sesame.'u-egypt' 0, potato.sesame.'m-egypt' 0, potato.sesame.'e-delta' 0, potato.sesame.'m-delta' 0, potato.sesame.'w-delta' 0, potato.'s-potato'.'u-egypt' 0, potato.'s-potato'.'m-egypt' 0, potato.'s-potato'.'e-delta' 0, potato.'s-potato'.'m-delta' 0, potato.'s-potato'.'w-delta' 0, potato.'s-tomato'.'u-egypt' 0, potato.'s-tomato'.'m-egypt' 0, potato.'s-tomato'.'e-delta' 0, potato.'s-tomato'.'m-delta' 0, potato.'s-tomato'.'w-delta' 0, potato.'s-veget'.'u-egypt' 0, potato.'s-veget'.'m-egypt' 0, potato.'s-veget'.'e-delta' 0, potato.'s-veget'.'m-delta' 0, potato.'s-veget'.'w-delta' 0, potato.'n-maize'.'u-egypt' 0, potato.'n-maize'.'m-egypt' 0, potato.'n-maize'.'e-delta' 0, potato.'n-maize'.'m-delta' 0, potato.'n-maize'.'w-delta' 0, potato.'n-potato'.'u-egypt' 0, potato.'n-potato'.'m-egypt' 0, potato.'n-potato'.'e-delta' 0, potato.'n-potato'.'m-delta' 0, potato.'n-potato'.'w-delta' 0, potato.'n-tomato'.'u-egypt' 0, potato.'n-tomato'.'m-egypt' 0, potato.'n-tomato'.'e-delta' 0, potato.'n-tomato'.'m-delta' 0, potato.'n-tomato'.'w-delta' 0, potato.'n-veget'.'u-egypt' 0, potato.'n-veget'.'m-egypt' 0, potato.'n-veget'.'e-delta' 0, potato.'n-veget'.'m-delta' 0, potato.'n-veget'.'w-delta' 0, potato.citrus.'u-egypt' 0, potato.citrus.'m-egypt' 0, potato.citrus.'e-delta' 0, potato.citrus.'m-delta' 0, potato.citrus.'w-delta' 0, potato.sugarcane.'u-egypt' 0, potato.sugarcane.'m-egypt' 0, potato.sugarcane.'e-delta' 0, potato.sugarcane.'m-delta' 0, potato.sugarcane.'w-delta' 0, potato.'veg-oil'.'u-egypt' 0, potato.'veg-oil'.'m-egypt' 0, potato.'veg-oil'.'e-delta' 0, potato.'veg-oil'.'m-delta' 0, potato.'veg-oil'.'w-delta' 0, potato.maize.'u-egypt' 0, potato.maize.'m-egypt' 0, potato.maize.'e-delta' 0, potato.maize.'m-delta' 0, potato.maize.'w-delta' 0, potato.'s+n-tomato'.'u-egypt' 0, potato.'s+n-tomato'.'m-egypt' 0, potato.'s+n-tomato'.'e-delta' 0, potato.'s+n-tomato'.'m-delta' 0, potato.'s+n-tomato'.'w-delta' 0, potato.potato.'u-egypt' 0, potato.potato.'m-egypt' 0, potato.potato.'e-delta' 0, potato.potato.'m-delta' 0, potato.potato.'w-delta' 0/
    con(c) /cotton 0.175, soyabeans 0.175, sesame 0.47/
    rep1(c,z,*,*)
    tlimit(c,*) /'w-onion'.exports 60, 'w-tomato'.exports 100, cotton.exports inf, 's+n-tomato'.exports 100, citrus.exports 110, potato.exports 150, rice.exports 300, wheat.imports 5000, 'horse-bean'.imports inf, maize.imports inf, 'veg-oil'.imports inf, lentils.imports 50, lentils.exports 0, 'horse-bean'.exports 0, 's+n-tomato'.imports 0, 'w-tomato'.imports 0, maize.exports 0, citrus.imports 0, cotton.imports 0, wheat.exports 0, 'veg-oil'.exports 0, potato.imports 0, rice.imports 0, 'w-onion'.imports 0/
    emply(*,r,*)
;

Scalars
    high /1.666/
    low /0.6/
    day /20/
    pnfl /178/
    pnfi /200/
    ppfl /200/
    ppfi /140/
    ptrl /1.5/
    ptri /3/
    grdf /0.06723/
    totmd /749576/
;

beta(cn) = demdat(cn,"base-p") / demdat(cn,"domes-cons") / demdat(cn,"elas");
alpha(cn) = demdat(cn,"base-p") - beta(cn) * demdat(cn,"domes-cons");
demdat(cn,"dem-a") = alpha(cn);
demdat(cn,"dem-b") = beta(cn);

cn(c) = yes$demdat(c,"domes-cons");
cf(c) = yes$sum(z, feed(c,z));

grdfcon(cf) = 1;

stran(r,rp) = tranc(r,rp);
dfyld(r,cf) = sum(z$(zr(z,r)), feed(cf,z) * grdfcon(cf));
netcs(c,r) = (sum(z$(zr(z,r)), tractor(c,z) * ptrl) + cropdat(c,"misc") + cropdat(c,"pest") + cropdat(c,"n-fer") * pnfl + ppfl * cropdat(c,"p-fer") - indprod(c,r) * prby(c))$yield(c,r);
yld(c,c,r) = yield(c,r);
yld("veg-oil",c,r) = yield(c,r) * con(c);
yld(cn,c,r) = yield(c,r);
rep1(c,z,"land",tm) = land(c,z,tm);
rep1(c,z,"land","total") = sum(tm, land(c,z,tm));
rep1(c,z,"water",tm) = water(c,z,tm);
rep1(c,z,"water","total") = sum(tm, water(c,z,tm));
rep1(c,z,"laborm",tm) = laborm(c,z,tm);
rep1(c,z,"laborm","total") = sum(tm, laborm(c,z,tm));
pe(c) = demdat(c,"export-p");
pm(c) = demdat(c,"import-p");
price(c) = demdat(c,"base-p");
regwatr(r,tm) = regwat(r,tm) * eff(r);
regwatr(r,"total") = sum(tm, regwatr(r,tm));
pmax(cn) = price(cn) * high;
pmin(cn) = price(cn) * low;
qmax(cn) = (pmin(cn) - alpha(cn)) / beta(cn);
qmin(cn) = (pmax(cn) - alpha(cn)) / beta(cn);
incr(cn) = (qmax(cn) - qmin(cn)) / (card(g) - 1);
qs(cn,g) = qmin(cn) + incr(cn) * (ord(g) - 1);
ws(cn,g) = alpha(cn) * qs(cn,g) + 0.5 * beta(cn) * sqr(qs(cn,g));
rs(cn,g) = alpha(cn) * qs(cn,g) + beta(cn) * sqr(qs(cn,g));

* ============================================
* Variables (Primal + Multipliers)
* ============================================

* Primal variables: Original decision variables from the NLP
* Multipliers:
*   ν (nu_*): Free multipliers for equality constraints
*   λ (lam_*): Positive multipliers for inequality constraints
*   π^L (piL_*): Positive multipliers for lower bounds
*   π^U (piU_*): Positive multipliers for upper bounds

Variables
    cps
    nu_demb(c)
    nu_conv(c)
    nu_fodb(r,c)
;

Positive Variables
    xcrop(r,c)
    imports(c)
    exports(c)
    natq(c,g)
    anut(nt,r)
    sales(c)
    trans(c,r,rp)
    fodder(r,c)
    tlab(r,tm)
    flab(r,tm)
    lam_comb(c)
    lam_labbal(r,tm)
    lam_vegetb(s,r)
    lam_nutb(nt,r)
    lam_gfodb(r)
;

* ============================================
* Variable Bounds
* ============================================

xcrop.up(r,cup) = upbnds(cup,r);
imports.up(c) = tlimit(c,"imports");
exports.up(c) = tlimit(c,"exports");
flab.up(r,tm) = agrreg(r,"farmers") * 0.4;

* ============================================
* Variable Initialization
* ============================================

* Initialize variables to avoid division by zero during model generation.
* Variables appearing in denominators (from log, 1/x derivatives) need
* non-zero initial values.
* POSITIVE variables are set to 1.

xcrop.l(r,c) = 1;
imports.l(c) = 1;
exports.l(c) = 1;
natq.l(c,g) = 1;
anut.l(nt,r) = 1;
sales.l(c) = 1;
trans.l(c,r,rp) = 1;
fodder.l(r,c) = 1;
tlab.l(r,tm) = 1;
flab.l(r,tm) = 1;

* ============================================
* Post-solve Calibration (variable .l references)
* ============================================

$onImplicitAssign
emply("farmers",r,tm) = flab.l(r,tm);
emply("farmers",r,"total") = sum(tm, flab.l(r,tm));
emply("temp-lab",r,tm) = tlab.l(r,tm);
emply("temp-lab",r,"total") = sum(tm, tlab.l(r,tm));
$offImplicitAssign

* ============================================
* Equations
* ============================================

* Stationarity: One equation per primal variable (except objvar)
* Complementarity: Equations for inequalities and bounds
* Equality constraints: Original equality constraints

Equations
    stat_anut(nt,r)
    stat_exports(c)
    stat_flab(r,tm)
    stat_fodder(r,c)
    stat_imports(c)
    stat_natq(c,g)
    stat_sales(c)
    stat_tlab(r,tm)
    stat_trans(c,r,rp)
    stat_xcrop(r,c)
    comp_comb(c)
    comp_gfodb(r)
    comp_labbal(r,tm)
    comp_nutb(nt,r)
    comp_vegetb(s,r)
    conv(c)
    demb(c)
    fodb(r,c)
    obj
;

* ============================================
* Equation Definitions
* ============================================

* Stationarity equations
stat_anut(nt,r).. (-1) * lam_nutb(nt,r) =E= 0;
stat_exports(c)$(cn(c)).. sum(cn, (-1) * nu_demb(cn)) =E= 0;
stat_flab(r,tm).. day * regwagm(r,tm) - lam_labbal(r,tm) =E= 0;
stat_fodder(r,c).. sum(cf, nu_fodb(r,cf)) - lam_gfodb(r) =E= 0;
stat_imports(c)$(cn(c)).. sum(cn, nu_demb(cn)) =E= 0;
stat_natq(c,g)$(cn(c)).. sum(cn, ((-1) * qs(cn,g)) * nu_demb(cn)) + sum(cn, nu_conv(cn)) =E= 0;
stat_sales(c)$(cn(c)).. sum(cn, (1 - los(cn)) * nu_demb(cn)) + sum(cn, lam_comb(cn)) =E= 0;
stat_tlab(r,tm).. 2 * day * regwagm(r,tm) - lam_labbal(r,tm) =E= 0;
stat_trans(c,r,rp).. stran(r,rp) =E= 0;
stat_xcrop(r,c).. netcs(c,r) + sum(cf, ((-1) * sum(z$(zr(z,r)), feed(cf,z))) * nu_fodb(r,cf)) + sum(cn, ((-1) * yld(cn,cn,r)) * lam_comb(cn)) + sum(s, 1$sv(s,c) * lam_vegetb(s,r)) =E= 0;

* Inequality complementarity equations
comp_comb(cn).. ((-1) * (sales(cn) - sum((r,c), xcrop(r,c) * yld(cn,c,r)))) =G= 0;
comp_gfodb(r).. ((-1) * (sum(cfg, fodder(r,cfg)) * grdf - sum(cfd, fodder(r,cfd)))) =G= 0;
comp_labbal(r,tm).. ((-1) * (sum((c,z)$(zr(z,r)), xcrop(r,c) * laborm(c,z,tm)) / day - (tlab(r,tm) + flab(r,tm)))) =G= 0;
comp_nutb(nt,r).. sum(cf, fodder(r,cf) * cropdat(cf,nt) * 0.01) + anut(nt,r) - agrreg(r,nt) =G= 0;
comp_vegetb(s,r).. ((-1) * (sum(c$(sv(s,c)), xcrop(r,c)) - veg(r,s) * 1.5)) =G= 0;

* Original equality equations
demb(cn).. sales(cn) * (1 - los(cn)) + imports(cn) =E= exports(cn) + sum(g, qs(cn,g) * natq(cn,g));
conv(cn).. sum(g, natq(cn,g)) =E= 1;
fodb(r,cf).. fodder(r,cf) =E= xcrop(r,cf) * sum(z$(zr(z,r)), feed(cf,z)) + sum(rp$(tranc(r,rp)), trans(cf,rp,r) - trans(cf,r,rp))$ct(cf);
obj.. cps =E= totmd + sum(cn, sum(g, natq(cn,g) * ws(cn,g)) + exports(cn) * pe(cn) - imports(cn) * pm(cn)) - sum((ct,r,rp), trans(ct,r,rp) * stran(r,rp)) - sum((r,c), xcrop(r,c) * netcs(c,r)) - sum((r,nt), anut(nt,r) * prnut(nt)) - sum((r,tm), (flab(r,tm) + 2 * tlab(r,tm)) * regwagm(r,tm) * day);


* ============================================
* Fix inactive variable instances
* ============================================

* Variables whose paired MCP equation is conditioned must be
* fixed for excluded instances to satisfy MCP matching.

exports.fx(c)$(not (cn(c))) = 0;
imports.fx(c)$(not (cn(c))) = 0;
natq.fx(c,g)$(not (cn(c))) = 0;
sales.fx(c)$(not (cn(c))) = 0;

* ============================================
* Model MCP Declaration
* ============================================

* Each line pairs an equation with a variable:
*   equation.variable
*
* This defines the complementarity problem:
*   equation ⊥ variable
*
* Meaning: equation = 0 if variable > 0
*          equation ≥ 0 if variable = 0

Model mcp_model /
    stat_anut.anut,
    stat_exports.exports,
    stat_flab.flab,
    stat_fodder.fodder,
    stat_imports.imports,
    stat_natq.natq,
    stat_sales.sales,
    stat_tlab.tlab,
    stat_trans.trans,
    stat_xcrop.xcrop,
    comp_comb.lam_comb,
    comp_gfodb.lam_gfodb,
    comp_labbal.lam_labbal,
    comp_nutb.lam_nutb,
    comp_vegetb.lam_vegetb,
    conv.nu_conv,
    demb.nu_demb,
    fodb.nu_fodb,
    obj.cps
/;

* ============================================
* Solve Statement
* ============================================

Solve mcp_model using MCP;

Scalar nlp2mcp_obj_val;
nlp2mcp_obj_val = cps.l;
Display nlp2mcp_obj_val;
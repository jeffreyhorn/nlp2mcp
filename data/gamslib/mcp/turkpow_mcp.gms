    dd(b,*) /peak.duration 526, peak.demand 3365, high.duration 2540, high.demand 2550, medium.duration 3066, medium.demand 2050, low.duration 2628, low.demand 1520/
    length(time)
    d(b,te)
    dur(b)
    opcostt(m,v,t)
    capcostt(m,v,t)
    sigma(m)
    delta(t)
    bs(b,b)
    vs(t,v)
    kit(m,v)
;

Scalars
    rho /0.11/
    prr /0.05/
    r /0.5/
    g /0.11/
;

$onImplicitAssign
mt(m) = (not mh(m));
$offImplicitAssign

length(time) = ord(time) - 1;
sigma(mt) = rho / (1 - (1 + rho) ** ((-1) * mdatat(mt,"life")));
sigma(mh) = rho / (1 - (1 + rho) ** ((-1) * mdatah(mh,"life")));
bs(b,bp) = ord(b) >= ord(bp);
vs(t,v) = ord(t) >= ord(v);
kit(mt,"1978") = mdatat(mt,"initcap");
d(b,te) = round(dd(b,"demand") * (1 + g) ** length(te), 0);
delta(t) = (1 + rho) ** ((-1) * length(t));
dur(b) = sum(bp$(bs(b,bp)), dd(bp,"duration")) / sum(bp, dd(bp,"duration"));
opcostt(m,v,t)$(vs(t,v)) = mdatat(m,"opcost") * (1 + mdatat(m,"opcost-g")) ** length(v);
capcostt(m,v,t)$(vs(t,v)) = mdatat(m,"capcost") * (1 + mdatat(m,"capcost-g")) ** length(v);

execError = 0;

* ============================================
* Variables (Primal + Multipliers)
* ============================================

* Primal variables: Original decision variables from the NLP
* Multipliers:
*   ν (nu_*): Free multipliers for equality constraints
*   λ (lam_*): Positive multipliers for inequality constraints
*   π^L (piL_*): Positive multipliers for lower bounds
*   π^U (piU_*): Positive multipliers for upper bounds

Variables
    phi
    phic(te)
    phio(te)
    htt(m)
    nu_cat(m)
    nu_ak(te)
    nu_ao(te)
;

Positive Variables
    hh(m,te)
    ht(m,v)
    zh(m,b,t)
    zt(m,v,b,t)
    lam_db(b,t)
    lam_pr(te)
    lam_cch(m,te)
    lam_cct(m,v,t)
    lam_ech(m,te)
    lam_hcc(te)
    lam_rch(m)
    piL_hh(m,te)
    piL_ht(m,v)
    piL_zh(m,b,t)
    piL_zt(m,v,b,t)
;

* ============================================
* Variable Bounds
* ============================================

hh.lo(mh,t) = hlo(mh,t);
hh.up(mh,t) = hup(mh,t);
ht.lo(mt,t) = tlo(mt,t);
ht.up(mt,t) = tup(mt,t);
htt.up(mt) = mdatat(mt,"maxcap");

* ============================================
* Variable Initialization
* ============================================

* Initialize variables to avoid division by zero during model generation.
* Variables appearing in denominators (from log, 1/x derivatives) need
* non-zero initial values.
* POSITIVE variables are set to 1.

hh.l(m,te) = 1;
hh.l(m,te) = min(hh.l(m,te), hh.up(m,te));
ht.l(m,v) = 1;
ht.l(m,v) = min(ht.l(m,v), ht.up(m,v));
zh.l(m,b,t) = 1;
zh.l(m,b,t) = min(zh.l(m,b,t), zh.up(m,b,t));
zt.l(m,v,b,t) = 1;
zt.l(m,v,b,t) = min(zt.l(m,v,b,t), zt.up(m,v,b,t));

* ============================================
* Equations
* ============================================

* Stationarity: One equation per primal variable (except objvar)
* Complementarity: Equations for inequalities and bounds
* Equality constraints: Original equality constraints

Equations
    stat_hh(m,te)
    stat_ht(m,v)
    stat_htt(m)
    stat_phic(te)
    stat_phio(te)
    stat_zh(m,b,t)
    stat_zt(m,v,b,t)
    comp_cch(mh,t)
    comp_cct(m,v,t)
    comp_db(b,t)
    comp_ech(mh,t)
    comp_hcc(t)
    comp_pr(t)
    comp_rch(mh)
    comp_lo_hh(m,te)
    comp_lo_ht(m,v)
    comp_lo_zh(m,b,t)
    comp_lo_zt(m,v,b,t)
    ak(t)
    ao(t)
    cat(m)
    obj
;

* ============================================
* Equation Definitions
* ============================================

* Index aliases to avoid 'Set is under control already' error
* (GAMS Error 125 when equation domain index is reused in sum)
Alias(mt, mt__);
Alias(t, t__);

* Stationarity equations
stat_hh(m,te).. (sum(v, ((-1) * (sigma(m) * mdatah(m,"capcost") * 1$(vs(te,v)))) * nu_ak(te)) + sum(v, ((-1) * (mdatah(m,"avail") * 1$(vs(te,v)))) * lam_pr(te)) + sum(v, ((-1) * (mdatah(m,"avail") * 1$(vs(te,v)))) * lam_cch(m,te)) + sum(v, ((-1) * (mdatah(m,"e-fact") * 1$(vs(te,v)))) * lam_ech(m,te)) + sum(v, 1$(vs(te,v)) * lam_hcc(te)) + lam_rch(m) - piL_hh(m,te))$(mh(m) and t(te)) =E= 0;
stat_ht(m,v).. (((-1) * nu_cat(m)) + sum((mt__,t), (((-1) * mdatat(mt__,"avail")) * lam_cct(mt__,v,t))$(vs(t,v))) - piL_ht(m,v))$(mt(m)) =E= 0;
stat_htt(m).. nu_cat(m)$(mt(m)) =E= 0;
stat_phic(te).. (sum(t__$(sameas(t__, te)), delta(t__)$(t(te))) + nu_ak(te))$(t(te)) =E= 0;
stat_phio(te).. (sum(t__$(sameas(t__, te)), delta(t__)$(t(te))) + nu_ao(te))$(t(te)) =E= 0;
stat_zh(m,b,t).. (((-1) * (mdatah(m,"opcost") * dur(b))) * nu_ao(t) + ((-1) * 1$(bs(b,b))) * lam_db(b,t) + lam_cch(m,t) + dur(b) * lam_ech(m,t) - piL_zh(m,b,t))$(mh(m)) =E= 0;
stat_zt(m,v,b,t).. (lam_cct(m,v,t)$(vs(t,v)) - piL_zt(m,v,b,t))$(mt(m)) =E= 0;

* Inequality complementarity equations
comp_cch(mh,t).. ((-1) * (sum(b, zh(mh,b,t)) - mdatah(mh,"avail") * (mdatah(mh,"initcap") + sum(v$(vs(t,v)), hh(mh,v))))) =G= 0;
comp_cct(mt,v,t)$(vs(t,v)).. ((-1) * (sum(b, zt(mt,v,b,t)) - mdatat(mt,"avail") * (kit(mt,v) + ht(mt,v)))) =G= 0;
comp_db(b,t).. sum(bp$(bs(bp,b)), sum(mh, zh(mh,bp,t)) + sum((mt,v)$(vs(t,v)), zt(mt,v,bp,t))) - d(b,t) =G= 0;
comp_ech(mh,t).. ((-1) * (sum(b, dur(b) * zh(mh,b,t)) - mdatah(mh,"e-fact") * (mdatah(mh,"initcap") + sum(v$(vs(t,v)), hh(mh,v))))) =G= 0;
comp_hcc(t).. ((-1) * (sum(mh, mdatah(mh,"initcap") + sum(v$(vs(t,v)), hh(mh,v))) - r * d("peak",t))) =G= 0;
comp_pr(t).. sum(mh, mdatah(mh,"avail") * (mdatah(mh,"initcap") + sum(v$(vs(t,v)), hh(mh,v)))) + sum(mt, mdatat(mt,"avail") * sum(v$(vs(t,v)), kit(mt,v) + ht(mt,v))) - (1 + prr) * d("peak",t) =G= 0;
comp_rch(mh).. ((-1) * (sum(t, hh(mh,t)) - mdatah(mh,"maxcap"))) =G= 0;

* Lower bound complementarity equations
comp_lo_hh(m,te).. hh(m,te) - 0 =G= 0;
comp_lo_ht(m,v).. ht(m,v) - 0 =G= 0;
comp_lo_zh(m,b,t).. zh(m,b,t) - 0 =G= 0;
comp_lo_zt(m,v,b,t).. zt(m,v,b,t) - 0 =G= 0;

* Original equality equations
cat(mt).. htt(mt) =E= sum(v, ht(mt,v));
ak(t).. phic(t) =E= sum(mh, sigma(mh) * mdatah(mh,"capcost") * sum(v$(vs(t,v)), hh(mh,v))) + sum(mt, sigma(mt) * sum(v, capcostt(mt,v,t) * ht(mt,v)));
ao(t).. phio(t) =E= sum(mh, mdatah(mh,"opcost") * sum(b, dur(b) * zh(mh,b,t))) + sum((mt,v)$(vs(t,v)), opcostt(mt,v,t) * sum(b, dur(b) * zt(mt,v,b,t)));
obj.. phi =E= sum(t, delta(t) * (phic(t) + phio(t)));


* ============================================
* Fix inactive variable instances
* ============================================

* Variables whose paired MCP equation is conditioned must be
* fixed for excluded instances to satisfy MCP matching.

hh.fx(m,te)$(not (mh(m) and t(te))) = 0;
piL_hh.fx(m,te)$(not (mh(m) and t(te))) = 0;
ht.fx(m,v)$(not (mt(m))) = 0;
piL_ht.fx(m,v)$(not (mt(m))) = 0;
htt.fx(m)$(not (mt(m))) = 0;
phic.fx(te)$(not (t(te))) = 0;
phio.fx(te)$(not (t(te))) = 0;
zh.fx(m,b,t)$(not (mh(m))) = 0;
piL_zh.fx(m,b,t)$(not (mh(m))) = 0;
zt.fx(m,v,b,t)$(not (mt(m))) = 0;
piL_zt.fx(m,v,b,t)$(not (mt(m))) = 0;
lam_cct.fx(mt,v,t)$(not (vs(t,v))) = 0;
nu_cat.fx(m)$(not (mt(m))) = 0;
lam_cch.fx(m,te)$(not (mh(m) and t(te))) = 0;
lam_cct.fx(m,v,t)$(not (mt(m))) = 0;
lam_ech.fx(m,te)$(not (mh(m) and t(te))) = 0;
lam_hcc.fx(te)$(not (t(te))) = 0;
lam_pr.fx(te)$(not (t(te))) = 0;
lam_rch.fx(m)$(not (mh(m))) = 0;
nu_ak.fx(te)$(not (t(te))) = 0;
nu_ao.fx(te)$(not (t(te))) = 0;
nu_cat.fx(m)$(not (mt(m))) = 0;

* ============================================
* Model MCP Declaration
* ============================================

* Each line pairs an equation with a variable:
*   equation.variable
*
* This defines the complementarity problem:
*   equation ⊥ variable
*
* Meaning: equation = 0 if variable > 0
*          equation ≥ 0 if variable = 0

Model mcp_model /
    stat_hh.hh,
    stat_ht.ht,
    stat_htt.htt,
    stat_phic.phic,
    stat_phio.phio,
    stat_zh.zh,
    stat_zt.zt,
    comp_cch.lam_cch,
    comp_cct.lam_cct,
    comp_db.lam_db,
    comp_ech.lam_ech,
    comp_hcc.lam_hcc,
    comp_pr.lam_pr,
    comp_rch.lam_rch,
    ak.nu_ak,
    ao.nu_ao,
    cat.nu_cat,
    obj.phi,
    comp_lo_hh.piL_hh,
    comp_lo_ht.piL_ht,
    comp_lo_zh.piL_zh,
    comp_lo_zt.piL_zt
/;

* ============================================
* Solve Statement
* ============================================

Solve mcp_model using MCP;

Scalar nlp2mcp_obj_val;
nlp2mcp_obj_val = phi.l;
Display nlp2mcp_obj_val;
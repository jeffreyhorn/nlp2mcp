Scalars
    rho /0.11/
    prr /0.05/
    r /0.5/
    g /0.11/
;

$onImplicitAssign
bs(b,bp) = ord(b) >= ord(bp);
length(time) = ord(time) - 1;
vs(t,v) = ord(t) >= ord(v);
mt(m) = (not mh(m));
d(b,te) = round(dd(b,"demand") * (1 + g) ** length(te), 0);
dur(b) = sum(bp$(bs(b,bp)), dd(bp,"duration")) / sum(bp, dd(bp,"duration"));
kit(mt,"1978") = mdatat(mt,"initcap");
opcostt(m,v,t)$(vs(t,v)) = mdatat(m,"opcost") * (1 + mdatat(m,"opcost-g")) ** length(v);
$offImplicitAssign

sigma(mt) = rho / (1 - (1 + rho) ** ((-1) * mdatat(mt,"life")));
sigma(mh) = rho / (1 - (1 + rho) ** ((-1) * mdatah(mh,"life")));
delta(t) = (1 + rho) ** ((-1) * length(t));
capcostt(m,v,t)$(vs(t,v)) = mdatat(m,"capcost") * (1 + mdatat(m,"capcost-g")) ** length(v);

execError = 0;

* Issue #1322: NA-cleanup for parameters with division-based assignments.
* If `<param>(d)` ended up NA/UNDF/inf at runtime (typically from
* zero-divisor arithmetic), reset to 0 so PATH's symbolic Jacobian
* doesn't produce ~1e30 coefficients.
dur(b)$(NOT (dur(b) > -inf and dur(b) < inf)) = 0;
sigma(m)$(NOT (sigma(m) > -inf and sigma(m) < inf)) = 0;

* ============================================
* Variables (Primal + Multipliers)
* ============================================

* Primal variables: Original decision variables from the NLP
* Multipliers:
*   ν (nu_*): Free multipliers for equality constraints
*   λ (lam_*): Positive multipliers for inequality constraints
*   π^L (piL_*): Positive multipliers for lower bounds
*   π^U (piU_*): Positive multipliers for upper bounds

Variables
    phi
    phic(te)
    phio(te)
    htt(m)
    nu_cat(m)
    nu_ak(te)
    nu_ao(te)
;

Positive Variables
    hh(m,te)
    ht(m,v)
    zh(m,b,t)
    zt(m,v,b,t)
    lam_db(b,te)
    lam_pr(te)
    lam_cch(m,te)
    lam_cct(m,v,te)
    lam_ech(m,te)
    lam_hcc(te)
    lam_rch(m)
    piL_hh(m,te)
    piL_ht(m,v)
    piL_zh(m,b,t)
    piL_zt(m,v,b,t)
    piU_hh(m,te)
    piU_htt(m)
;

* ============================================
* Variable Bounds
* ============================================

hh.lo(mh,t) = hlo(mh,t);
hh.up(mh,t) = hup(mh,t);
ht.lo(mt,t) = tlo(mt,t);
ht.up(mt,t) = tup(mt,t);
htt.up(mt) = mdatat(mt,"maxcap");

* ============================================
* Variable Initialization
* ============================================

* Initialize variables to avoid division by zero during model generation.
* Variables appearing in denominators (from log, 1/x derivatives) need
* non-zero initial values.
* POSITIVE variables are set to 1.

hh.l(m,te) = 1;
hh.l(m,te) = min(hh.l(m,te), hh.up(m,te));
ht.l(m,v) = 1;
ht.l(m,v) = min(ht.l(m,v), ht.up(m,v));
zh.l(m,b,t) = 1;
zh.l(m,b,t) = min(zh.l(m,b,t), zh.up(m,b,t));
zt.l(m,v,b,t) = 1;
zt.l(m,v,b,t) = min(zt.l(m,v,b,t), zt.up(m,v,b,t));

* ============================================
* Equations
* ============================================

* Stationarity: One equation per primal variable (except objvar)
* Complementarity: Equations for inequalities and bounds
* Equality constraints: Original equality constraints

Equations
    stat_hh(m,te)
    stat_ht(m,v)
    stat_htt(m)
    stat_phic(te)
    stat_phio(te)
    stat_zh(m,b,t)
    stat_zt(m,v,b,t)
    comp_cch(m,te)
    comp_cct(m,v,te)
    comp_db(b,te)
    comp_ech(m,te)
    comp_hcc(te)
    comp_pr(te)
    comp_rch(m)
    comp_lo_hh(m,te)
    comp_lo_ht(m,v)
    comp_lo_zh(m,b,t)
    comp_lo_zt(m,v,b,t)
    comp_up_hh(m,te)
    comp_up_htt(m)
    ak(te)
    ao(te)
    cat(m)
    obj
;

* ============================================
* Equation Definitions
* ============================================

* Index aliases to avoid 'Set is under control already' error
* (GAMS Error 125 when equation domain index is reused in sum)
Alias(mt, mt__);
Alias(t, t__);

* Stationarity equations
stat_hh(m,te).. (sum(v, (((-1) * (sigma(m) * mdatah(m,"capcost") * 1$(vs(te,v)))) * nu_ak(te))$(t(te))) + sum(v, (((-1) * (mdatah(m,"avail") * 1$(vs(te,v)))) * lam_pr(te))$(t(te))) + sum(v, (((-1) * (mdatah(m,"avail") * 1$(vs(te,v)))) * lam_cch(m,te))$(mh(m) and t(te))) + sum(v, (((-1) * (mdatah(m,"e-fact") * 1$(vs(te,v)))) * lam_ech(m,te))$(mh(m) and t(te))) + sum(v, (1$(vs(te,v)) * lam_hcc(te))$(t(te))) + (lam_rch(m)$(mh(m)))$(mh(m) and t(te)) - piL_hh(m,te) + piU_hh(m,te))$(mh(m) and t(te) and hh.up(m,te) - hh.lo(m,te) > 1e-10) =E= 0;

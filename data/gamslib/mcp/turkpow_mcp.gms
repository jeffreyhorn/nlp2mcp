    hup(m,te) /'hydro-1'.'1978' inf, 'hydro-1'.'1983' inf, 'hydro-2'.'1978' inf, 'hydro-2'.'1983' inf, 'hydro-3'.'1978' inf, 'hydro-3'.'1983' inf, 'hydro-5'.'1978' inf, 'hydro-5'.'1983' inf, 'hydro-6'.'1978' inf, 'hydro-6'.'1983' inf, 'hydro-7'.'1978' inf, 'hydro-7'.'1983' inf, 'hydro-1'.'1988' inf, 'hydro-1'.'1993' inf, 'hydro-1'.'1998' inf, 'hydro-1'.'2005' inf, 'hydro-2'.'1988' inf, 'hydro-2'.'1993' inf, 'hydro-2'.'1998' inf, 'hydro-2'.'2005' inf, 'hydro-3'.'1988' inf, 'hydro-3'.'1993' inf, 'hydro-3'.'1998' inf, 'hydro-3'.'2005' inf, 'hydro-4'.'1988' inf, 'hydro-4'.'1993' inf, 'hydro-4'.'1998' inf, 'hydro-4'.'2005' inf, 'hydro-5'.'1988' inf, 'hydro-5'.'1993' inf, 'hydro-5'.'1998' inf, 'hydro-5'.'2005' inf, 'hydro-6'.'1988' inf, 'hydro-6'.'1993' inf, 'hydro-6'.'1998' inf, 'hydro-6'.'2005' inf, 'hydro-7'.'1988' inf, 'hydro-7'.'1993' inf, 'hydro-7'.'1998' inf, 'hydro-7'.'2005' inf, 'hydro-8'.'1988' inf, 'hydro-8'.'1993' inf, 'hydro-8'.'1998' inf, 'hydro-8'.'2005' inf, 'hydro-9'.'1988' inf, 'hydro-9'.'1993' inf, 'hydro-9'.'1998' inf, 'hydro-9'.'2005' inf, 'hydro-10'.'1988' inf, 'hydro-10'.'1993' inf, 'hydro-10'.'1998' inf, 'hydro-10'.'2005' inf, 'hydro-11'.'1988' inf, 'hydro-11'.'1993' inf, 'hydro-11'.'1998' inf, 'hydro-11'.'2005' inf, 'hydro-12'.'1988' inf, 'hydro-12'.'1993' inf, 'hydro-12'.'1998' inf, 'hydro-12'.'2005' inf, 'hydro-13'.'1988' inf, 'hydro-13'.'1993' inf, 'hydro-13'.'1998' inf, 'hydro-13'.'2005' inf, 'hydro-4'.'1978' 250/

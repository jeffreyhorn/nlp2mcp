pwm0(i) = pm0(i) / ((1 + tm0(i)) * er);
alphl(lc,i) = wdist(i,lc) * wa0(lc) * xle(i,lc) / (pva0(i) * xd0(i));
delta(it) = pm0(it) / pd0(it) * (m0(it) / xxd0(it)) ** (1 + rhoc(it));
delta(it) = delta(it) / (1 + delta(it));

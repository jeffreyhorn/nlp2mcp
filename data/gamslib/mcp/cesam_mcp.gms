T0(ii,"TOTAL") = sum(jj, SAM(ii,jj));
Abar0(ii,jj) = SAM(ii,jj) / SAM("TOTAL",jj);
Target0(ii) = (sam(ii,"total") + sam("total",ii)) / 2;
T1(ii,jj) = T0(ii,jj) - redsam(ii,jj);
T1("Total",jj) = sum(ii, T1(ii,jj));
T1(ii,"Total") = sum(jj, T1(ii,jj));

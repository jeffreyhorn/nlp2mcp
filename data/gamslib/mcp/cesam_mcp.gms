sigmay2("gdpfc2") = 0.05 * gdpfc0;
sigmay2("gdp2") = 0.05 * gdp0;
vbar2(macro,"1") = (-3) * sigmay2(macro);
vbar2(macro,"2") = (-1) * sigmay2(macro);
vbar2(macro,"4") = 1 * sigmay2(macro);
vbar2(macro,"5") = 3 * sigmay2(macro);


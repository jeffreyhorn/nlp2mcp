p.l(t) = min(max(p.l(t), 1e-6), p.up(t));
td.l('1975') = 18.0;
td.l('1976') = 18.0;
td.l('1977') = 18.0;
td.l('1978') = 18.0;
td.l('1979') = 18.0;

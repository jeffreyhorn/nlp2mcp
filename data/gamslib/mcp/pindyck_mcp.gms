td.l('1989') = 18.0;
td.l('1990') = 18.0;
td.l(t) = min(max(td.l(t), 1e-6), td.up(t));
s.l('1975') = 7.0;
s.l('1976') = 7.0;
s.l('1977') = 7.0;
s.l('1978') = 7.0;
s.l('1979') = 7.0;
s.l('1980') = 7.0;
s.l('1981') = 7.0;
s.l('1982') = 7.0;
